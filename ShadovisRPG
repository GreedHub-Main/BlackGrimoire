local MiscTab = Window:CreateTab("Miscellaneous", 4483362458)

local spawnedMaps = {}
local spawnedEnemies = {}

MiscTab:CreateButton({
	Name = "Spawn Maps",
	Callback = function()
		local source = ReplicatedStorage:FindFirstChild("UnloadedMaps")
		local dest = workspace:FindFirstChild("Maps")
		if source and dest then
			for _, v in ipairs(source:GetChildren()) do
				local clone = v:Clone()
				clone.Parent = dest
				table.insert(spawnedMaps, clone)
			end
		end
	end
})

MiscTab:CreateButton({
	Name = "Spawn Enemies",
	Callback = function()
		local source = ReplicatedStorage:FindFirstChild("UnloadedEnemies")
		local dest = workspace:FindFirstChild("NPCs")
		if source and dest then
			for _, v in ipairs(source:GetChildren()) do
				local clone = v:Clone()
				clone.Parent = dest
				table.insert(spawnedEnemies, clone)
			end
		end
	end
})

MiscTab:CreateButton({
	Name = "Clean Up Maps",
	Callback = function()
		for _, v in ipairs(spawnedMaps) do
